# FitStart — Root .gitignore
node_modules/
.env
.env.local
.env.development.local
.env.test.local

# Build outputs
client/build/

# Uploaded files (use cloud storage in production)
server/uploads/*
!server/uploads/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# IDE
.vscode/
.idea/
